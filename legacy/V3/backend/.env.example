# FastAPI Backend Configuration

# Server settings
FP_HOST=0.0.0.0
FP_PORT=8000
FP_DEBUG=false

# CORS (comma-separated origins)
FP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Simulation limits (proof-of-concept)
FP_MAX_ITERATIONS=100000
FP_MAX_BATCH_SIZE=10
FP_MAX_MATRIX_SIZE=20
FP_DEFAULT_CHUNK_SIZE=100

# Job management
FP_JOB_TTL_SECONDS=3600
FP_MAX_CONCURRENT_JOBS=3
