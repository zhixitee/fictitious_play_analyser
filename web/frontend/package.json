{
  "name": "fp-analyzer-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node --max-old-space-size=4096 --import tsx ./server/localServer.ts",
    "server:8g": "node --max-old-space-size=8192 --import tsx ./server/localServer.ts",
    "server:12g": "node --max-old-space-size=12288 --import tsx ./server/localServer.ts",
    "server:16g": "node --max-old-space-size=16384 --import tsx ./server/localServer.ts",
    "server:32g": "node --max-old-space-size=32768 --import tsx ./server/localServer.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^4.6.0",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.8",
    "ws": "^8.19.0"
  }
}
